+          .eq('type', 'reward')
+          .eq('user_id', userId)
+          .ilike('description', 'Referral Commission%');
+        const totalEarned = earnTx ? earnTx.reduce((sum, tx) => sum + Number(tx.amount || 0), 0) : 0;
